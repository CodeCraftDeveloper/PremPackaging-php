Options +FollowSymLinks -MultiViews
RewriteEngine On

# 1. Redirect homepage variants to the root URL
RewriteCond %{THE_REQUEST} \s/+(.*/)?index(?:\.php)?(?:[?\s/]|$) [NC]
RewriteRule ^index(?:\.php)?/?$ /%1 [R=301,L]

# 2. Redirect direct .php access and path-info variants to extensionless URLs
RewriteCond %{THE_REQUEST} \s/+(.*/)?(.+?)\.php(?:/[^?\s]*)?[\s?] [NC]
RewriteRule ^ /%1%2 [R=301,L]

# 3. Internally rewrite extensionless URLs to .php if the file exists
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]
